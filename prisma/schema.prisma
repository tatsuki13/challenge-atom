generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                 String        @id @default(cuid())
  displayName        String
  consentFamilyShare Boolean       @default(false)
  favoriteTopics     String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  conversations      Conversation[]
  dailyMetrics       DailyMetric[]
  riskEvents         RiskEvent[]
}

model Conversation {
  id             String      @id @default(cuid())
  profileId      String
  profile        Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title          String
  moodScoreStart Int?
  moodScoreEnd   Int?
  startedAt      DateTime    @default(now())
  endedAt        DateTime?
  messages       Message[]
  riskEvents     RiskEvent[]

  @@index([profileId, startedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  emotionLabel   String?
  riskLevel      String       @default("none")
  createdAt      DateTime     @default(now())
  riskEvents     RiskEvent[]

  @@index([conversationId, createdAt])
  @@index([riskLevel])
}

model DailyMetric {
  id                    String   @id @default(cuid())
  profileId             String
  profile               Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date                  DateTime
  conversationCount     Int      @default(0)
  userMessageCount      Int      @default(0)
  assistantMessageCount Int      @default(0)
  userCharCount         Int      @default(0)
  estimatedMinutes      Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([profileId, date])
}

model RiskEvent {
  id             String        @id @default(cuid())
  profileId      String
  profile        Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  messageId      String?
  message        Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  riskLevel      String
  note           String
  createdAt      DateTime      @default(now())

  @@index([profileId, createdAt])
  @@index([riskLevel])
}
